{
  "name": "shopease-capstone",
  "version": "1.0.0",
  "private": true,
  "description": "ShopEase — full-stack e-commerce capstone with QA + Playwright",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "seed": "node database/seed.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report automation/reports/html-report",
    "allure:generate": "allure generate automation/reports/allure-results --clean -o automation/reports/allure-report",
    "allure:open": "allure open automation/reports/allure-report"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.6.0",
    "nodemon": "^3.1.7"
  }
}
